# Issue Picket - Cron Job Example
# Add this to your crontab with: crontab -e

# Run issue-picket every day at 9 AM
0 9 * * * cd /path/to/doll-cli && /usr/bin/node dist/scheduler.js >> /var/log/issue-picket.log 2>&1

# Alternative: Run every hour during business hours (9 AM to 6 PM)
# 0 9-18 * * * cd /path/to/doll-cli && /usr/bin/node dist/scheduler.js >> /var/log/issue-picket.log 2>&1

# Alternative: Run every Monday at 9 AM
# 0 9 * * 1 cd /path/to/doll-cli && /usr/bin/node dist/scheduler.js >> /var/log/issue-picket.log 2>&1
